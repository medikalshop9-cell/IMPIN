# ─────────────────────────────────────────────────────────────────────────────
# IMPIN — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
SUPABASE_SECRET_KEY=sb_secret_<your-secret-key>
SUPABASE_PROJECT_REF=<your-project-ref>

# ── Database (Direct Connection) ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<your-db-password>@db.<your-project-ref>.supabase.co:5432/postgres

# ── Scraper Settings ──────────────────────────────────────────────────────────
SCRAPER_MIN_DELAY_S=2
SCRAPER_MAX_DELAY_S=6
SCRAPER_MAX_RETRIES=3

# ── Pipeline Settings ─────────────────────────────────────────────────────────
IMPI_BASE_PERIOD=2026-01
RANDOM_SEED=42

# ── Dashboard ─────────────────────────────────────────────────────────────────
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=localhost
